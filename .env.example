# Local storage
PATCHSCOPE_DATA_DIR=.data
PATCHSCOPE_DATABASE_URL_OVERRIDE=

# Browser access from another local origin
PATCHSCOPE_ALLOWED_ORIGINS=["http://127.0.0.1:8501","http://localhost:8501"]

# Optional provider-backed synthesis. Leave the key blank for deterministic offline review.
PATCHSCOPE_AI_MODE=auto
PATCHSCOPE_OPENAI_MODEL=gpt-5-mini
PATCHSCOPE_OPENAI_API_KEY=

# Optional authenticated GitHub reads. Public pull requests work without a token.
PATCHSCOPE_GITHUB_TOKEN=

# Resource and analyzer bounds
PATCHSCOPE_MAX_FILE_BYTES=500000
PATCHSCOPE_MAX_REVIEW_BYTES=2000000
PATCHSCOPE_MAX_FILES=100
PATCHSCOPE_ANALYZER_TIMEOUT_SECONDS=20
PATCHSCOPE_GITHUB_TIMEOUT_SECONDS=10
